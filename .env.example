# Chaves da API do Coinbase Developer Platform (CDP)
# Obtenha em: https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME="organizations/org-.../apiKeys/..."
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# Chave da API do OpenAI
# Obtenha em: https://platform.openai.com/
OPENAI_API_KEY="sk-proj-..."

# Configuração da Blockchain
# Use 'base-sepolia' para testes e 'base-mainnet' para produção
NETWORK_ID="base-sepolia"

# Configuração do Servidor Backend
PORT=8000
HOST="0.0.0.0"
